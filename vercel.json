{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/onochoo", "destination": "/index.html" },
    { "source": "/mutigoeul", "destination": "/index.html" },
    { "source": "/settings", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/send-add-song-reminders",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/send-reminders",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cleanup-push-subscriptions",
      "schedule": "0 18 * * *"
    }
  ]
}
